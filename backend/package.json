    "@grpc/proto-loader": "^0.8.0",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.8.4",
    "@solana/web3.js": "^1.95.8",
    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}

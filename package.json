{
  "name": "fastpoker",
  "version": "1.0.0",
  "description": "Fast Poker - On-chain Texas Hold'em with MagicBlock Ephemeral Rollups",
  "main": "setup-devnet-local.js",
  "scripts": {
    "setup": "node setup-devnet-local.js",
    "airdrop": "node airdrop-poker.js",
    "build:anchor": "cd programs/fastpoker && cargo build-sbf",
    "build:steel": "cd contracts && ./build.sh",
    "build:client": "cd client && npm run build",
    "dev:client": "cd client && npm run dev",
    "test": "cd tests && npm test",
    "test:poker": "cd tests && npm run test:poker",
    "test:magicblock": "cd tests && npm run test:magicblock",
    "install:all": "npm install && cd client && npm install && cd ../tests && npm install",
    "clean": "rm -rf target/deploy programs/fastpoker/target"
  },
  "keywords": [
    "solana",
    "poker",
    "devnet",
    "magicblock",
    "ephemeral-rollups"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@magicblock-labs/ephemeral-rollups-sdk": "^0.8.5",
    "@magicblock-labs/gum-sdk": "^3.0.10",
    "@metaplex-foundation/js": "^0.20.1",
    "@metaplex-foundation/mpl-token-metadata": "^3.3.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.8",
    "bs58": "^6.0.0",
    "magic-router-sdk": "^1.0.10"
  },
  "devDependencies": {
    "ed25519-hd-key": "^1.3.0"
  }
}
